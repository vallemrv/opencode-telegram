# Environment Variables
# Copy this file to .env and fill in your values

# ─── Telegram ────────────────────────────────────────────────────────────────
# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKENS=

# Comma-separated list of Telegram user IDs allowed to use the bot
# Example: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

# Admin user ID who receives notifications about unauthorized access attempts
# Example: ADMIN_USER_ID=123456789
ADMIN_USER_ID=

# If true, the process exits when an unauthorized user tries to use the bot
AUTO_KILL=false

# ─── OpenCode ────────────────────────────────────────────────────────────────
# OpenCode server URL (default: http://localhost:4096)
OPENCODE_SERVER_URL=http://localhost:4096

# Default model to use when no model is selected (provider/model-id)
OPENCODE_DEFAULT_MODEL=github-copilot/claude-sonnet-4.6

# ─── Gitea ───────────────────────────────────────────────────────────────────
# URL of your Gitea instance
# Example: http://192.168.1.100:3000
GITEA_URL=

# Gitea personal access token (Settings → Applications → Access Tokens)
GITEA_TOKEN=

# Local directory where git repos are stored.
# The bot will create this directory if it doesn't exist.
# Supports ~ expansion.  Default: ~/proyectos/gitea-projects
GITEA_DEFAULT_WORKDIR=~/proyectos/gitea-projects

# ─── Background Agent (/run command) ────────────────────────────────────────
# Default model for background opencode run tasks (provider/model-id)
# If not set, falls back to OPENCODE_DEFAULT_MODEL
BACKGROUND_MODEL=github-copilot/claude-sonnet-4.6

# Default working directory for /run tasks (optional, the command will ask)
# Supports ~ expansion. If empty, /run always asks the user.
BACKGROUND_WORKDIR=


# Auto-delete timeout for confirmation messages in milliseconds (0 = disable)
MESSAGE_DELETE_TIMEOUT=10000

# ─── Media ───────────────────────────────────────────────────────────────────
# Temporary directory for uploaded files
MEDIA_TMP_LOCATION=/tmp/telegramcoder_media

# Set to true to clean up the media directory on startup
CLEAN_UP_MEDIADIR=false
