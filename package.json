{
  "name": "@tommertom/telegramcoder",
  "version": "0.8.11",
  "description": "AI-powered Telegram bot with OpenCode integration for intelligent coding assistance via Telegram",
  "main": "dist/app.js",
  "bin": {
    "telegramcoder": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "dot-env.template",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node esbuild.config.js",
    "build:prod": "NODE_ENV=production node esbuild.config.js",
    "build:tsc": "tsc --outDir dist",
    "dev": "nodemon --watch src --ext ts --exec \"node esbuild.config.js && node dist/app.js\"",
    "start": "node ./dist/cli.js",
    "watch": "tsc --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "doPublish": "npm run build:prod && npm version patch && npm publish --access public",
    "pm2:start": "npm run build:prod && pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop telegramCoder",
    "pm2:restart": "npm run build:prod && pm2 startOrRestart ecosystem.config.cjs",
    "pm2:delete": "pm2 delete telegramCoder",
    "pm2:logs": "pm2 logs telegramCoder",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status"
  },
  "keywords": [
    "telegram",
    "bot",
    "ai",
    "copilot",
    "claude",
    "cursor",
    "terminal",
    "xterm",
    "pty",
    "coding-assistant",
    "cli",
    "automation"
  ],
  "author": "Tommertom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tommertom/telegramCoder.git"
  },
  "bugs": {
    "url": "https://github.com/Tommertom/telegramCoder/issues"
  },
  "homepage": "https://github.com/Tommertom/telegramCoder#readme",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "nodemon": "^3.1.10",
    "ts-prune": "^0.10.3",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.3.12",
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.2",
    "express": "^5.2.1",
    "grammy": "^1.38.2",
    "zod": "^4.1.5"
  }
}
